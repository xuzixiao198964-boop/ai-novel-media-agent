# 基础配置
APP_NAME=AI智能内容创作平台
APP_VERSION=2.0.0
DEBUG=false
HOST=0.0.0.0
PORT=9000

# 安全配置
SECRET_KEY=change-me-in-production-use-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY_SALT=change-me-api-key-salt

# 数据库配置
DATABASE_URL=postgresql+asyncpg://ainovel:ainovel@localhost:5432/ai_novel_media

# Redis配置
REDIS_URL=redis://localhost:6379/0

# CORS配置
CORS_ORIGINS=*

# 文件存储配置
DATA_DIR=/data/ai-novel-media
UPLOAD_DIR=/data/ai-novel-media/uploads
OUTPUT_DIR=/data/ai-novel-media/outputs
NOVEL_DIR=/data/ai-novel-media/novels
VIDEO_DIR=/data/ai-novel-media/videos
TEMP_DIR=/data/ai-novel-media/temp
MEMORY_DIR=/data/ai-novel-media/memory

# AI模型配置
DEEPSEEK_API_KEY=your-deepseek-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# TTS配置
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# 视频生成配置
FISH_AUDIO_API_KEY=
SILICONFLOW_API_KEY=
DASHSCOPE_API_KEY=

# 支付配置
ALIPAY_APP_ID=
WECHAT_APP_ID=

# OAuth配置
WECHAT_OAUTH_APP_ID=
DOUYIN_OAUTH_CLIENT_KEY=

# 发布平台配置
DOUYIN_OPEN_API_KEY=
XIAOHONGSHU_API_KEY=

# 公网访问地址
PUBLIC_BASE_URL=http://localhost:9000

# 开发模式配置
MOCK_PAYMENT=false
MOCK_PUBLISH=true
